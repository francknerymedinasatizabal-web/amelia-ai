OPENAI_API_KEY=sk-aqui-tu-key
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Base de datos (local: SQLite por defecto; producción: PostgreSQL en Render)
# DATABASE_URL=sqlite:///./amelia.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# (Render a veces entrega postgres:// — el backend lo normaliza a psycopg2)

# Producción (Render / otro host)
# COMPANY_NAME=Central de Aires del Pacífico
# ASSISTANT_NAME=Amelia
# CORS_ORIGINS=https://tu-app.vercel.app,https://tu-app-git-main.vercel.app
# Si necesitas permitir cualquier origen (solo pruebas): CORS_ORIGINS=*

# URL pública del frontend (QR y enlaces). En producción: https://tu-app.vercel.app
# PUBLIC_APP_URL=https://tu-app.vercel.app

# Render inyecta PORT; en local no hace falta
# PORT=10000

# Primer admin: tras migrar, en Postgres:
